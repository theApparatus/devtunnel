#!/usr/bin/env bash
set -euo pipefail

#
# devtunnel - manage cloudflare tunnel + tailscale routes for dev projects
#
# Usage:
#   devtunnel add <name> <port> [--public|--locked]    Add a CF route
#   devtunnel add <name> <port> --serve               Tailscale Serve (tailnet only)
#   devtunnel add <name> <port> --funnel              Tailscale Funnel (public *.ts.net)
#   devtunnel add <name> <port> --dir /path --cmd "npm run dev"  Auto-manage the app process
#   devtunnel rm <name>                                Remove a project route + service
#   devtunnel set <name> [--cmd C] [--dir D] [--port P]  Update project settings
#   devtunnel codes <project> [add|edit|rm]            Manage access codes for locked projects
#   devtunnel ls                                       List active project routes
#   devtunnel restart                                  Restart the tunnel service
#   devtunnel restart <name>                           Restart a project's app service
#   devtunnel stop <name>                              Stop a project's app service
#   devtunnel logs <name> [-f]                          Show (or tail) a project's app logs
#   devtunnel log [N]                                  Show last N operations log entries
#   devtunnel status                                   Show tunnel service status
#
# Requires (Tailscale):
#   tailscale CLI installed and connected (sudo tailscale up)
#
# Config stored in: ~/.cloudflared/devtunnel.json
#

DOMAIN="app.fixshifted.com"            # ← Set by install.sh or edit manually
CONFIG_DIR="$HOME/.cloudflared"
TUNNEL_CONFIG="$CONFIG_DIR/config.yml"
STATE_FILE="$HOME/.config/devtunnel/state.json"
TUNNEL_ID="246d495b-e6a0-4bc1-8643-21e84914e8e9"        # ← Set by install.sh or edit manually
SERVICE_PREFIX="devtunnel-app"

# Tailscale
TS_HOSTNAME=""
TS_FUNNEL_PORTS=(443 8443 10000)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
NC='\033[0m'

die() { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info() { echo -e "${GREEN}>>>${NC} $*"; }
warn() { echo -e "${YELLOW}>>>${NC} $*"; }

# ---- Structured Logging ----

LOG_DIR="$HOME/.local/share/devtunnel/logs"
LOG_FILE="$LOG_DIR/devtunnel.log"
MAX_LOG_SIZE=$((5 * 1024 * 1024))

log_event() {
    local level="$1" action="$2" project="${3:-}" msg="${4:-}"
    mkdir -p "$LOG_DIR"
    if [[ -f "$LOG_FILE" ]]; then
        local size; size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
        (( size > MAX_LOG_SIZE )) && mv -f "$LOG_FILE" "${LOG_FILE}.1"
    fi
    printf '{"ts":"%s","level":"%s","source":"cli","action":"%s","project":"%s","msg":"%s"}\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$level" "$action" "$project" "$msg" >> "$LOG_FILE"
}

# ---- Startup readiness helpers ----

wait_for_ready() {
    local name="$1" port="$2" timeout="${3:-15}"
    echo -ne "${CYAN}>>>${NC} Waiting for ${name} on port ${port}..."
    local elapsed=0
    while (( elapsed < timeout )); do
        local code
        code=$(curl -so /dev/null -w '%{http_code}' --max-time 2 "http://localhost:${port}/" 2>/dev/null || echo "000")
        if [[ "$code" =~ ^[23] ]]; then
            echo -e " ${GREEN}ready${NC} (HTTP ${code})"
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    echo -e " ${RED}not ready${NC} (HTTP ${code:-000} after ${timeout}s)"
    return 1
}

show_recent_journal() {
    local name="$1"
    local svc="$(service_name "$name")"
    echo -e "${YELLOW}--- recent logs for ${svc} ---${NC}"
    journalctl --user -u "$svc" --no-pager -n 5 2>/dev/null || true
    echo -e "${YELLOW}---${NC}"
}

# Source credentials if available
if [[ -f "$CONFIG_DIR/.env" ]]; then
    set -a; source "$CONFIG_DIR/.env"; set +a
fi

# Initialize state file
init_state() {
    mkdir -p "$(dirname "$STATE_FILE")"
    if [[ ! -f "$STATE_FILE" ]]; then
        local secret
        secret=$(openssl rand -hex 32)
        (umask 077; echo "{\"projects\":{},\"cookie_secret\":\"${secret}\"}" > "$STATE_FILE")
    fi
    # Ensure cookie_secret exists
    if [[ "$(jq -r '.cookie_secret // empty' "$STATE_FILE" 2>/dev/null)" == "" ]]; then
        local secret
        secret=$(openssl rand -hex 32)
        jq --arg s "$secret" '.cookie_secret = $s' "$STATE_FILE" > "${STATE_FILE}.tmp" \
            && mv "${STATE_FILE}.tmp" "$STATE_FILE"
    fi
    # Ensure restrictive permissions even on existing files
    chmod 600 "$STATE_FILE" 2>/dev/null || true
}

# Read state
get_projects() {
    jq -r '.projects' "$STATE_FILE"
}

get_project() {
    jq -r ".projects[\"$1\"] // empty" "$STATE_FILE"
}

# Rebuild the cloudflared config.yml from state
rebuild_config() {
    local config=""
    config+="tunnel: ${TUNNEL_ID}\n"
    config+="credentials-file: ${CONFIG_DIR}/${TUNNEL_ID}.json\n"
    config+="\n"
    config+="ingress:\n"

    # Add each project route (cloudflare only)
    local names
    names=$(jq -r '.projects | to_entries[] | select((.value.provider // "cloudflare") != "tailscale") | .key' "$STATE_FILE" 2>/dev/null || true)
    for name in $names; do
        local port
        port=$(jq -r ".projects[\"$name\"].port" "$STATE_FILE")
        config+="  - hostname: \"${name}.${DOMAIN}\"\n"
        config+="    service: http://localhost:${port}\n"
    done

    # Catch-all
    config+="  - service: http_status:404\n"

    echo -e "$config" > "$TUNNEL_CONFIG"
}

# ---- App Service Management ----

service_name() {
    echo "${SERVICE_PREFIX}-${1}.service"
}

create_app_service() {
    local name="$1" dir="$2" cmd="$3" port="$4"

    # Escape single quotes for safe interpolation into ExecStart='...'
    local safe_cmd="${cmd//\'/\'\\\'\'}"

    local svc_file="$HOME/.config/systemd/user/$(service_name "$name")"
    mkdir -p "$HOME/.config/systemd/user"

    cat > "$svc_file" <<SVCEOF
[Unit]
Description=devtunnel app: ${name} (port ${port})
After=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=${dir}
ExecStartPre=-/usr/bin/fuser -k ${port}/tcp
ExecStart=/bin/bash -c '${safe_cmd}'
Restart=always
RestartSec=3
Environment=PORT=${port}
Environment=NODE_ENV=development

[Install]
WantedBy=default.target
SVCEOF

    systemctl --user daemon-reload
    systemctl --user enable --now "$(service_name "$name")" 2>/dev/null
    info "App service created and started: $(service_name "$name")"
    log_event "info" "service_create" "$name" "dir=${dir} cmd=${cmd} port=${port}"

    if wait_for_ready "$name" "$port" 15; then
        log_event "info" "service_ready" "$name" "port ${port} ready"
    else
        show_recent_journal "$name"
        log_event "warn" "service_not_ready" "$name" "port ${port} not ready after 15s"
    fi
}

remove_app_service() {
    local name="$1"
    local svc="$(service_name "$name")"
    if systemctl --user is-enabled "$svc" &>/dev/null 2>&1; then
        systemctl --user disable --now "$svc" 2>/dev/null
        info "App service stopped and disabled"
    fi
    local svc_file="$HOME/.config/systemd/user/$svc"
    if [[ -f "$svc_file" ]]; then
        rm -f "$svc_file"
        systemctl --user daemon-reload
        info "App service removed"
        log_event "info" "service_remove" "$name" "removed app service"
    fi
}

get_app_service_status() {
    local name="$1"
    local svc="$(service_name "$name")"
    if systemctl --user is-active "$svc" &>/dev/null 2>&1; then
        echo "running"
    elif systemctl --user is-enabled "$svc" &>/dev/null 2>&1; then
        echo "stopped"
    else
        echo "none"
    fi
}

# ---- Tailscale helpers ----

detect_tailscale() {
    if ! command -v tailscale &>/dev/null; then
        die "Tailscale is not installed. Install from https://tailscale.com/download"
    fi
    local ts_status
    ts_status=$(tailscale status --json 2>/dev/null) || die "Tailscale is not connected. Run: sudo tailscale up"
    local backend_state
    backend_state=$(echo "$ts_status" | jq -r '.BackendState // empty')
    if [[ "$backend_state" != "Running" ]]; then
        die "Tailscale is not connected. Run: sudo tailscale up"
    fi
    TS_HOSTNAME=$(echo "$ts_status" | jq -r '.Self.DNSName // empty' | sed 's/\.$//')
    if [[ -z "$TS_HOSTNAME" ]]; then
        die "Could not determine Tailscale hostname"
    fi
}

ts_allocate_port() {
    local mode="$1"
    local used_ports
    used_ports=$(jq -r '.projects | to_entries[] | select((.value.provider // "cloudflare") == "tailscale") | .value.ts_port // empty' "$STATE_FILE" 2>/dev/null || true)

    if [[ "$mode" == "funnel" ]]; then
        for p in "${TS_FUNNEL_PORTS[@]}"; do
            if ! echo "$used_ports" | grep -qx "$p"; then
                echo "$p"
                return
            fi
        done
        die "All Tailscale Funnel ports (443, 8443, 10000) are in use. Remove a Funnel project first."
    else
        # Serve: try funnel ports first, then 4443, 5443, 6443, ...
        for p in "${TS_FUNNEL_PORTS[@]}"; do
            if ! echo "$used_ports" | grep -qx "$p"; then
                echo "$p"
                return
            fi
        done
        local base=4443
        while true; do
            if ! echo "$used_ports" | grep -qx "$base"; then
                echo "$base"
                return
            fi
            base=$((base + 1000))
            if (( base > 65535 )); then
                die "No available Tailscale ports"
            fi
        done
    fi
}

ts_add() {
    local local_port="$1" ext_port="$2" mode="$3"
    info "Setting up Tailscale ${mode} on port ${ext_port}..."
    if ! tailscale "$mode" "--https=$ext_port" --bg "localhost:$local_port" 2>/dev/null; then
        if [[ "$mode" == "funnel" ]]; then
            die "Tailscale Funnel failed. Enable it in your tailnet admin console."
        else
            die "Tailscale Serve failed."
        fi
    fi
}

ts_remove() {
    local ext_port="$1" mode="$2"
    info "Removing Tailscale ${mode} on port ${ext_port}..."
    tailscale "$mode" "--https=$ext_port" off 2>/dev/null || true
}

ts_url() {
    local ext_port="$1"
    if [[ "$ext_port" == "443" ]]; then
        echo "https://${TS_HOSTNAME}"
    else
        echo "https://${TS_HOSTNAME}:${ext_port}"
    fi
}

# ---- Tunnel restart helper ----

restart_tunnel_service() {
    if systemctl --user is-active cloudflared.service &>/dev/null 2>&1; then
        systemctl --user restart cloudflared.service
        info "Tunnel service restarted"
        log_event "info" "tunnel_restart" "" "restarted user service"
    elif systemctl is-active cloudflared.service &>/dev/null 2>&1; then
        warn "Restart the tunnel: sudo systemctl restart cloudflared"
        log_event "warn" "tunnel_restart" "" "system service requires manual restart"
    else
        warn "Start the tunnel: cloudflared tunnel run devbox"
        log_event "warn" "tunnel_restart" "" "no tunnel service found"
    fi
}

# ---- Commands ----

cmd_add() {
    local name="" port="" access="public" dir="" cmd="" provider="cloudflare" ts_port_override=""

    # Parse args
    [[ $# -ge 2 ]] || die "Usage: devtunnel add <name> <port> [--public | --locked | --serve | --funnel] [--dir /path --cmd 'npm run dev']"
    name="$1"; port="$2"; shift 2

    # Validate name (subdomain safe)
    [[ "$name" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]] || die "Name must be a valid subdomain (lowercase alphanumeric and hyphens)"
    # Validate port
    [[ "$port" =~ ^[0-9]+$ ]] && (( port >= 1 && port <= 65535 )) || die "Port must be 1-65535"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --public)   access="public"; shift ;;
            --locked)   access="locked"; shift ;;
            --serve)    provider="tailscale"; access="serve"; shift ;;
            --funnel)   provider="tailscale"; access="funnel"; shift ;;
            --ts-port)  ts_port_override="$2"; shift 2 ;;
            --dir)      dir="$2"; shift 2 ;;
            --cmd)      cmd="$2"; shift 2 ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    # Check if already exists
    if [[ -n "$(get_project "$name")" ]]; then
        die "Project '${name}' already exists. Remove it first: devtunnel rm ${name}"
    fi

    # Validate dir if provided
    if [[ -n "$dir" && ! -d "$dir" ]]; then
        die "Directory does not exist: $dir"
    fi

    init_state

    if [[ "$provider" == "tailscale" ]]; then
        # Tailscale path
        detect_tailscale

        local ts_port
        if [[ -n "$ts_port_override" ]]; then
            ts_port="$ts_port_override"
        else
            ts_port=$(ts_allocate_port "$access")
        fi

        ts_add "$port" "$ts_port" "$access"

        # Update state
        jq --arg name "$name" \
           --arg port "$port" \
           --arg access "$access" \
           --arg provider "tailscale" \
           --argjson ts_port "$ts_port" \
           --arg dir "$dir" \
           --arg cmd "$cmd" \
           '.projects[$name] = {port: ($port|tonumber), provider: $provider, access: $access, ts_port: $ts_port, dir: $dir, cmd: $cmd}' \
           "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

        local url
        url=$(ts_url "$ts_port")
        log_event "info" "add" "$name" "provider=tailscale port=${port} access=${access}"
        info "Added ${CYAN}${name}${NC} -> localhost:${port}"
        if [[ "$access" == "funnel" ]]; then
            info "Access: ${YELLOW}FUNNEL${NC} (public via *.ts.net)"
        else
            info "Access: ${GREEN}SERVE${NC} (tailnet only)"
        fi

        # Create app service if dir and cmd provided
        if [[ -n "$dir" && -n "$cmd" ]]; then
            create_app_service "$name" "$dir" "$cmd" "$port"
        fi

        echo ""
        info "URL: ${url}"
    else
        # Cloudflare path
        # Update state
        if [[ "$access" == "locked" ]]; then
            local auth_user="$name"
            local auth_salt auth_pw auth_hash auth_pass
            auth_salt=$(openssl rand -hex 16)
            auth_pw=$(openssl rand -hex 16)
            auth_hash=$(printf '%s' "${auth_salt}${auth_pw}" | sha256sum | cut -d' ' -f1)
            auth_pass="${auth_salt}:${auth_hash}"

            jq --arg name "$name" \
               --arg port "$port" \
               --arg access "$access" \
               --arg provider "cloudflare" \
               --arg dir "$dir" \
               --arg cmd "$cmd" \
               --arg auth_user "$auth_user" \
               --arg auth_pass "$auth_pass" \
               '.projects[$name] = {port: ($port|tonumber), provider: $provider, access: $access, auth_user: $auth_user, auth_pass: $auth_pass, invite_codes: [], dir: $dir, cmd: $cmd}' \
               "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        else
            jq --arg name "$name" \
               --arg port "$port" \
               --arg access "$access" \
               --arg provider "cloudflare" \
               --arg dir "$dir" \
               --arg cmd "$cmd" \
               '.projects[$name] = {port: ($port|tonumber), provider: $provider, access: $access, dir: $dir, cmd: $cmd}' \
               "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        fi

        # Rebuild config and restart
        rebuild_config

        log_event "info" "add" "$name" "provider=cloudflare port=${port} access=${access}"
        info "Added ${CYAN}${name}.${DOMAIN}${NC} -> localhost:${port}"
        if [[ "$access" == "public" ]]; then
            info "Access: ${YELLOW}PUBLIC${NC} (no auth)"
        else
            info "Access: ${GREEN}LOCKED${NC}"
            info "Auth user: ${auth_user}"
            info "Auth pass: ${auth_pw}"
            info "Create invite codes: devtunnel codes ${name} add user@example.com"
        fi

        # Create app service if dir and cmd provided
        if [[ -n "$dir" && -n "$cmd" ]]; then
            create_app_service "$name" "$dir" "$cmd" "$port"
        fi

        restart_tunnel_service

        echo ""
        info "URL: https://${name}.${DOMAIN}"
    fi
}

cmd_rm() {
    [[ $# -ge 1 ]] || die "Usage: devtunnel rm <name>"
    local name="$1"

    init_state
    local project
    project=$(get_project "$name")
    [[ -n "$project" ]] || die "Project '${name}' not found"

    local proj_provider
    proj_provider=$(echo "$project" | jq -r '.provider // "cloudflare"')

    if [[ "$proj_provider" == "tailscale" ]]; then
        # Tailscale path
        local ts_port ts_access
        ts_port=$(echo "$project" | jq -r '.ts_port // empty')
        ts_access=$(echo "$project" | jq -r '.access // "serve"')
        if [[ -n "$ts_port" ]]; then
            ts_remove "$ts_port" "$ts_access"
        fi
    fi

    # Remove app service if it exists
    remove_app_service "$name"

    # Remove from state
    jq --arg name "$name" 'del(.projects[$name])' "$STATE_FILE" > "${STATE_FILE}.tmp" \
        && mv "${STATE_FILE}.tmp" "$STATE_FILE"

    if [[ "$proj_provider" == "tailscale" ]]; then
        info "Removed ${name} (Tailscale)"
    else
        rebuild_config
        info "Removed ${name}.${DOMAIN}"
        restart_tunnel_service
    fi
    log_event "info" "remove" "$name" "provider=${proj_provider}"
}

cmd_ls() {
    init_state

    local count
    count=$(jq '.projects | length' "$STATE_FILE")

    if [[ "$count" -eq 0 ]]; then
        echo "No active project tunnels."
        echo ""
        echo "Add one:  devtunnel add myproject 3000 --public"
        echo "          devtunnel add myproject 3000 --serve"
        echo "          devtunnel add myproject 3000 --public --dir ~/projects/myapp --cmd 'npm run dev'"
        return
    fi

    # Detect tailscale hostname for URL generation
    if command -v tailscale &>/dev/null; then
        local ts_status_json
        ts_status_json=$(tailscale status --json 2>/dev/null || true)
        if [[ -n "$ts_status_json" ]]; then
            TS_HOSTNAME=$(echo "$ts_status_json" | jq -r '.Self.DNSName // empty' | sed 's/\.$//')
        fi
    fi

    printf "\n${CYAN}%-18s %-10s %-7s %-9s %-10s %-38s %s${NC}\n" "NAME" "PROVIDER" "PORT" "ACCESS" "SERVICE" "URL" "CMD"
    printf "%-18s %-10s %-7s %-9s %-10s %-38s %s\n" "----" "--------" "----" "------" "-------" "---" "---"

    jq -r '.projects | to_entries[] | "\(.key)\t\(.value.port)\t\(.value.access)\t\(.value.provider // "cloudflare")\t\(.value.ts_port // "")\t\(.value.cmd // "")"' "$STATE_FILE" | \
    while IFS=$'\t' read -r name port access proj_provider ts_port cmd; do
        local access_display svc_display url provider_display

        case "$access" in
            public)  access_display="${YELLOW}public${NC}" ;;
            locked)  access_display="${GREEN}locked${NC}" ;;
            serve)   access_display="${GREEN}serve${NC}" ;;
            funnel)  access_display="${YELLOW}funnel${NC}" ;;
            *)       access_display="$access" ;;
        esac

        if [[ "$proj_provider" == "tailscale" ]]; then
            provider_display="${PURPLE}tailscale${NC}"
            if [[ -n "$TS_HOSTNAME" && -n "$ts_port" ]]; then
                if [[ "$ts_port" == "443" ]]; then
                    url="https://${TS_HOSTNAME}"
                else
                    url="https://${TS_HOSTNAME}:${ts_port}"
                fi
            else
                url="(tailscale)"
            fi
        else
            provider_display="${CYAN}cloudflare${NC}"
            url="https://${name}.${DOMAIN}"
        fi

        local svc_status
        svc_status=$(get_app_service_status "$name")
        case "$svc_status" in
            running) svc_display="${GREEN}running${NC}" ;;
            stopped) svc_display="${RED}stopped${NC}" ;;
            *)       svc_display="${YELLOW}—${NC}" ;;
        esac

        printf "%-18s %-10b %-7s %-9b %-10b %-38s %s\n" "$name" "$provider_display" "$port" "$access_display" "$svc_display" "$url" "${cmd:--}"
    done
    echo ""
}

cmd_restart() {
    if [[ $# -ge 1 ]]; then
        # Restart a specific project's app service
        local name="$1"
        local svc="$(service_name "$name")"
        if systemctl --user is-enabled "$svc" &>/dev/null 2>&1; then
            systemctl --user restart "$svc"
            info "Restarted app service for ${name}"
            log_event "info" "restart" "$name" "restarted app service"

            local port
            port=$(jq -r ".projects[\"$name\"].port // empty" "$STATE_FILE" 2>/dev/null || true)
            if [[ -n "$port" ]]; then
                if wait_for_ready "$name" "$port" 15; then
                    log_event "info" "service_ready" "$name" "port ${port} ready after restart"
                else
                    show_recent_journal "$name"
                    log_event "warn" "service_not_ready" "$name" "port ${port} not ready after restart"
                fi
            fi
        else
            die "No app service found for '${name}'. Add one with --dir and --cmd."
        fi
        return
    fi

    # Restart the tunnel
    rebuild_config
    restart_tunnel_service
}

cmd_stop() {
    [[ $# -ge 1 ]] || die "Usage: devtunnel stop <name>"
    local name="$1"
    local svc="$(service_name "$name")"
    if systemctl --user is-active "$svc" &>/dev/null 2>&1; then
        systemctl --user stop "$svc"
        info "Stopped app service for ${name}"
        log_event "info" "stop" "$name" "stopped app service"
    else
        warn "App service for '${name}' is not running"
    fi
}

cmd_logs() {
    [[ $# -ge 1 ]] || die "Usage: devtunnel logs <name> [--follow|-f]"
    local name="$1"; shift
    local follow=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --follow|-f) follow=true; shift ;;
            *) die "Unknown option: $1" ;;
        esac
    done
    local svc="$(service_name "$name")"
    if [[ "$follow" == true ]]; then
        journalctl --user -u "$svc" -f --no-pager
    else
        journalctl --user -u "$svc" -n 50 --no-pager
    fi
}

cmd_status() {
    echo ""
    if systemctl --user is-active cloudflared.service &>/dev/null 2>&1; then
        info "Cloudflare Tunnel: ${GREEN}running${NC} (user)"
    elif systemctl is-active cloudflared.service &>/dev/null 2>&1; then
        info "Cloudflare Tunnel: ${GREEN}running${NC} (system)"
    else
        warn "Cloudflare Tunnel: ${RED}not running${NC}"
    fi

    # Tailscale status
    if command -v tailscale &>/dev/null; then
        local ts_status_json
        ts_status_json=$(tailscale status --json 2>/dev/null || true)
        if [[ -n "$ts_status_json" ]]; then
            local backend_state
            backend_state=$(echo "$ts_status_json" | jq -r '.BackendState // empty')
            if [[ "$backend_state" == "Running" ]]; then
                local ts_host
                ts_host=$(echo "$ts_status_json" | jq -r '.Self.DNSName // empty' | sed 's/\.$//')
                info "Tailscale: ${GREEN}connected${NC} (${ts_host})"
            else
                warn "Tailscale: ${RED}not connected${NC}"
            fi
        else
            warn "Tailscale: ${RED}not connected${NC}"
        fi
    else
        info "Tailscale: ${YELLOW}not installed${NC}"
    fi

    echo ""
    cloudflared tunnel info devbox 2>/dev/null || true
    echo ""
    cmd_ls
}

cmd_help() {
    cat <<'EOF'

  devtunnel - expose local dev projects via Cloudflare Tunnel or Tailscale

  CLOUDFLARE:
    devtunnel add <name> <port> --public              Public, no auth
    devtunnel add <name> <port> --locked              Locked, requires access codes

  TAILSCALE:
    devtunnel add <name> <port> --serve               Tailscale Serve (tailnet only)
    devtunnel add <name> <port> --funnel              Tailscale Funnel (public *.ts.net)
    devtunnel add <name> <port> --funnel --ts-port 8443   Specific Tailscale port

  GENERAL:
    devtunnel rm <name>                                Remove project + app service
    devtunnel set <name> [--cmd C] [--dir D] [--port P]  Update project settings
    devtunnel ls                                       List projects
    devtunnel restart                                  Restart CF tunnel
    devtunnel restart <name>                           Restart a project's app
    devtunnel stop <name>                              Stop a project's app
    devtunnel logs <name> [-f|--follow]                 Show (or tail) a project's app logs
    devtunnel log [N]                                  Show last N operations log entries
    devtunnel status                                   Show status (CF + Tailscale)

  ACCESS CODES (for locked projects):
    devtunnel codes <project>                          List codes
    devtunnel codes <project> add <email> [--max N] [--expire DT]
    devtunnel codes <project> add --no-email [--max N] [--expire DT]
    devtunnel codes <project> edit <code-prefix> [--email E] [--max N] [--expire DT] [--reset-uses]
    devtunnel codes <project> rm <code-prefix>

  APP SERVICE (auto-managed process):
    devtunnel add myapp 3000 --public --dir ~/projects/myapp --cmd "npm run dev"
    devtunnel add myapp 3000 --serve --dir ~/projects/myapp --cmd "npm run dev"

    --dir PATH    Working directory for the app
    --cmd CMD     Start command (creates a systemd service that auto-restarts)

  MANAGEMENT:
    devtunnel web                                  Start web management UI (port 7000)

  NOTES:
    Tailscale Funnel only supports ports 443, 8443, 10000 (max 3 Funnel projects).
    Tailscale Serve supports any port and is private to your tailnet.

EOF
}

# ---- Code Management ----

cmd_codes() {
    [[ $# -ge 1 ]] || die "Usage: devtunnel codes <project> [add|edit|rm]"
    local name="$1"; shift

    init_state
    local project
    project=$(get_project "$name")
    [[ -n "$project" ]] || die "Project '${name}' not found"

    local subcmd="list"
    if [[ $# -gt 0 ]]; then
        case "$1" in
            add|edit|rm|list) subcmd="$1"; shift ;;
        esac
    fi

    case "$subcmd" in
        list) cmd_codes_list "$name" ;;
        add)  cmd_codes_add "$name" "$@" ;;
        edit) cmd_codes_edit "$name" "$@" ;;
        rm)   cmd_codes_rm "$name" "$@" ;;
    esac
}

cmd_codes_list() {
    local name="$1"
    local codes
    codes=$(jq -r ".projects[\"$name\"].invite_codes // []" "$STATE_FILE")
    local count
    count=$(echo "$codes" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
        echo "No codes for project '${name}'."
        echo ""
        echo "Add one:  devtunnel codes ${name} add user@example.com"
        return
    fi

    printf "\n${CYAN}%-34s %-28s %-10s %-22s %s${NC}\n" "CODE" "EMAIL" "USES" "EXPIRE" "STATUS"
    printf "%-34s %-28s %-10s %-22s %s\n" "----" "-----" "----" "------" "------"

    echo "$codes" | jq -c '.[]' | while IFS= read -r entry; do
        local code email uses max_uses expires_at
        code=$(echo "$entry" | jq -r '.code')
        email=$(echo "$entry" | jq -r '.email // empty')
        uses=$(echo "$entry" | jq -r '.uses // 0')
        max_uses=$(echo "$entry" | jq -r '.max_uses // empty')
        expires_at=$(echo "$entry" | jq -r '.expires_at // empty')

        local uses_display="${uses}"
        if [[ -n "$max_uses" && "$max_uses" != "null" && "$max_uses" -gt 0 ]] 2>/dev/null; then
            uses_display="${uses}/${max_uses}"
        else
            uses_display="${uses}/∞"
        fi

        local status="${GREEN}active${NC}"
        if [[ -n "$max_uses" && "$max_uses" != "null" && "$max_uses" -gt 0 && "$uses" -ge "$max_uses" ]] 2>/dev/null; then
            status="${RED}exhausted${NC}"
        fi
        if [[ -n "$expires_at" && "$expires_at" != "null" ]]; then
            local exp_epoch now_epoch
            exp_epoch=$(date -d "$expires_at" +%s 2>/dev/null || echo 0)
            now_epoch=$(date -u +%s)
            if (( exp_epoch > 0 && now_epoch >= exp_epoch )); then
                status="${RED}expired${NC}"
            fi
        fi

        local email_display="${email:-${YELLOW}anonymous${NC}}"
        local expire_display="${expires_at:-—}"

        printf "%-34s %-28b %-10s %-22s %b\n" "${code:0:32}" "$email_display" "$uses_display" "$expire_display" "$status"
    done
    echo ""
}

cmd_codes_add() {
    local name="$1"; shift
    local email="" no_email=false max_uses="" expires_at=""

    # Parse: first positional arg is email (unless --no-email comes first)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-email) no_email=true; shift ;;
            --max)      max_uses="$2"; shift 2 ;;
            --expire)   expires_at="$2"; shift 2 ;;
            -*)         die "Unknown option: $1" ;;
            *)
                if [[ -z "$email" ]]; then
                    email="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    if [[ "$no_email" == false && -z "$email" ]]; then
        die "Usage: devtunnel codes ${name} add <email> [--max N] [--expire DT] or --no-email"
    fi
    if [[ "$no_email" == true ]]; then
        email=""
    fi

    local code
    code=$(openssl rand -hex 16 | tr '[:lower:]' '[:upper:]' | head -c 12)

    local email_json="null"
    if [[ -n "$email" ]]; then
        email_json=$(printf '%s' "$email" | jq -Rs '.')
    fi
    local max_json="null"
    if [[ -n "$max_uses" ]]; then
        max_json="$max_uses"
    fi
    local expire_json="null"
    if [[ -n "$expires_at" ]]; then
        expire_json=$(printf '%s' "$expires_at" | jq -Rs '.')
    fi

    jq --arg name "$name" \
       --arg code "$code" \
       --argjson email "$email_json" \
       --argjson max_uses "$max_json" \
       --argjson expires_at "$expire_json" \
       '.projects[$name].invite_codes = ((.projects[$name].invite_codes // []) + [{code: $code, email: $email, expires_at: $expires_at, max_uses: $max_uses, uses: 0}])' \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

    log_event "info" "code_add" "$name" "code=${code:0:8}... email=${email:-anonymous}"
    info "Code created: ${CYAN}${code}${NC}"
    if [[ -n "$email" ]]; then
        info "Email: ${email}"
    else
        info "Email: ${YELLOW}anonymous${NC}"
    fi
    if [[ -n "$max_uses" ]]; then info "Max uses: ${max_uses}"; fi
    if [[ -n "$expires_at" ]]; then info "Expires: ${expires_at}"; fi
}

cmd_codes_edit() {
    local name="$1"; shift
    [[ $# -ge 1 ]] || die "Usage: devtunnel codes ${name} edit <code-prefix> [--email E] [--max N] [--expire DT] [--reset-uses]"
    local prefix="$1"; shift

    local new_email="" new_max="" new_expire="" reset_uses=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --email)      new_email="$2"; shift 2 ;;
            --max)        new_max="$2"; shift 2 ;;
            --expire)     new_expire="$2"; shift 2 ;;
            --reset-uses) reset_uses=true; shift ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    # Find matching code by prefix
    local match_count
    match_count=$(jq --arg name "$name" --arg prefix "$prefix" \
        '[.projects[$name].invite_codes // [] | .[] | select(.code | startswith($prefix))] | length' "$STATE_FILE")

    [[ "$match_count" -eq 0 ]] && die "No code matching prefix '${prefix}'"
    [[ "$match_count" -gt 1 ]] && die "Multiple codes match prefix '${prefix}'. Use a longer prefix."

    # Build jq update expression
    local jq_expr='.projects[$name].invite_codes = [.projects[$name].invite_codes[] | if (.code | startswith($prefix)) then'
    local jq_updates=""

    if [[ -n "$new_email" ]]; then
        jq_updates+=' | .email = $new_email'
    fi
    if [[ -n "$new_max" ]]; then
        jq_updates+=' | .max_uses = ($new_max | tonumber)'
    fi
    if [[ -n "$new_expire" ]]; then
        jq_updates+=' | .expires_at = $new_expire'
    fi
    if [[ "$reset_uses" == true ]]; then
        jq_updates+=' | .uses = 0'
    fi

    [[ -z "$jq_updates" ]] && die "No changes specified"

    jq_expr+=" (. ${jq_updates}) else . end]"

    jq --arg name "$name" \
       --arg prefix "$prefix" \
       --arg new_email "$new_email" \
       --arg new_max "$new_max" \
       --arg new_expire "$new_expire" \
       "$jq_expr" \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

    log_event "info" "code_edit" "$name" "prefix=${prefix}"
    info "Code updated"
}

cmd_codes_rm() {
    local name="$1"; shift
    [[ $# -ge 1 ]] || die "Usage: devtunnel codes ${name} rm <code-prefix>"
    local prefix="$1"

    local match_count
    match_count=$(jq --arg name "$name" --arg prefix "$prefix" \
        '[.projects[$name].invite_codes // [] | .[] | select(.code | startswith($prefix))] | length' "$STATE_FILE")

    [[ "$match_count" -eq 0 ]] && die "No code matching prefix '${prefix}'"
    [[ "$match_count" -gt 1 ]] && die "Multiple codes match prefix '${prefix}'. Use a longer prefix."

    jq --arg name "$name" --arg prefix "$prefix" \
       '.projects[$name].invite_codes = [.projects[$name].invite_codes[] | select(.code | startswith($prefix) | not)]' \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

    log_event "info" "code_rm" "$name" "prefix=${prefix}"
    info "Code removed"
}

cmd_set() {
    [[ $# -ge 1 ]] || die "Usage: devtunnel set <name> [--cmd CMD] [--dir DIR] [--port PORT]"
    local name="$1"; shift

    init_state
    local project
    project=$(get_project "$name")
    [[ -n "$project" ]] || die "Project '${name}' not found"

    local new_cmd="" new_dir="" new_port=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cmd)  new_cmd="$2"; shift 2 ;;
            --dir)  new_dir="$2"; shift 2 ;;
            --port) new_port="$2"; shift 2 ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    [[ -n "$new_cmd" || -n "$new_dir" || -n "$new_port" ]] || die "At least one of --cmd, --dir, or --port is required"

    # Validate new port
    if [[ -n "$new_port" ]]; then
        [[ "$new_port" =~ ^[0-9]+$ ]] && (( new_port >= 1 && new_port <= 65535 )) || die "Port must be 1-65535"
    fi

    # Validate new dir
    if [[ -n "$new_dir" && ! -d "$new_dir" ]]; then
        die "Directory does not exist: $new_dir"
    fi

    local changes=""

    # Update fields in state
    if [[ -n "$new_cmd" ]]; then
        jq --arg name "$name" --arg cmd "$new_cmd" \
            '.projects[$name].cmd = $cmd' "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        changes+="cmd=${new_cmd} "
    fi
    if [[ -n "$new_dir" ]]; then
        jq --arg name "$name" --arg dir "$new_dir" \
            '.projects[$name].dir = $dir' "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        changes+="dir=${new_dir} "
    fi
    if [[ -n "$new_port" ]]; then
        jq --arg name "$name" --argjson port "$new_port" \
            '.projects[$name].port = $port' "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
        changes+="port=${new_port} "
    fi

    info "Updated ${name}: ${changes}"

    # Re-read project after updates
    project=$(get_project "$name")
    local cur_cmd cur_dir cur_port
    cur_cmd=$(echo "$project" | jq -r '.cmd // empty')
    cur_dir=$(echo "$project" | jq -r '.dir // empty')
    cur_port=$(echo "$project" | jq -r '.port')

    # If cmd or dir changed and both are set, recreate systemd unit + restart
    if [[ (-n "$new_cmd" || -n "$new_dir") && -n "$cur_cmd" && -n "$cur_dir" ]]; then
        create_app_service "$name" "$cur_dir" "$cur_cmd" "$cur_port"
        info "App service recreated and restarted"
    fi

    # If port changed, also rebuild tunnel config and restart (for CF projects)
    if [[ -n "$new_port" ]]; then
        local proj_provider
        proj_provider=$(echo "$project" | jq -r '.provider // "cloudflare"')
        if [[ "$proj_provider" != "tailscale" ]]; then
            rebuild_config
            restart_tunnel_service
        fi
        # Recreate service if cmd+dir are set (port changed in env)
        if [[ -z "$new_cmd" && -z "$new_dir" && -n "$cur_cmd" && -n "$cur_dir" ]]; then
            create_app_service "$name" "$cur_dir" "$cur_cmd" "$cur_port"
            info "App service recreated with new port"
        fi
    fi

    log_event "info" "set" "$name" "${changes}"
}

cmd_log() {
    local n="${1:-50}"
    if [[ ! -f "$LOG_FILE" ]]; then
        echo "No log entries yet."
        return
    fi
    tail -n "$n" "$LOG_FILE" | while IFS= read -r line; do
        local level action project msg ts
        level=$(echo "$line" | jq -r '.level // empty' 2>/dev/null) || continue
        action=$(echo "$line" | jq -r '.action // empty' 2>/dev/null)
        project=$(echo "$line" | jq -r '.project // empty' 2>/dev/null)
        msg=$(echo "$line" | jq -r '.msg // empty' 2>/dev/null)
        ts=$(echo "$line" | jq -r '.ts // empty' 2>/dev/null)
        local source_field
        source_field=$(echo "$line" | jq -r '.source // empty' 2>/dev/null)
        local color="$NC"
        case "$level" in
            error) color="$RED" ;;
            warn)  color="$YELLOW" ;;
            info)  color="$GREEN" ;;
        esac
        printf "${color}%-5s${NC} %-20s %-8s %-14s %-18s %s\n" "$level" "$ts" "$source_field" "$action" "$project" "$msg"
    done
}

cmd_healthcheck() {
    local state_dir="$HOME/.local/share/devtunnel"
    local hc_state="$state_dir/healthcheck-state.json"
    mkdir -p "$state_dir"

    # Initialize healthcheck state if missing
    if [[ ! -f "$hc_state" ]]; then
        echo '{}' > "$hc_state"
    fi

    # Check cloudflared service
    if ! systemctl --user is-active cloudflared.service &>/dev/null 2>&1; then
        log_event "warn" "healthcheck" "" "cloudflared not running, restarting"
        systemctl --user restart cloudflared.service 2>/dev/null || true
        log_event "info" "healthcheck" "" "cloudflared restart attempted"
    fi

    init_state

    local now
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Check each project with a running app service
    local names
    names=$(jq -r '.projects | keys[]' "$STATE_FILE" 2>/dev/null || true)
    local hc_data
    hc_data=$(cat "$hc_state")

    for name in $names; do
        local svc_status
        svc_status=$(get_app_service_status "$name")
        if [[ "$svc_status" != "running" ]]; then
            continue
        fi

        local port
        port=$(jq -r ".projects[\"$name\"].port" "$STATE_FILE")

        # Probe the port with HTTP status capture
        local http_code
        http_code=$(curl -so /dev/null -w '%{http_code}' --max-time 3 "http://localhost:${port}/" 2>/dev/null || echo "000")

        # Read existing entry (handle both legacy number and new object format)
        local prev_entry prev_failures prev_last_restart
        prev_entry=$(echo "$hc_data" | jq -r --arg name "$name" '.[$name] // empty')
        if [[ -z "$prev_entry" || "$prev_entry" == "null" ]]; then
            prev_failures=0
            prev_last_restart="null"
        elif echo "$prev_entry" | jq -e 'type == "number"' &>/dev/null; then
            # Legacy format: plain number
            prev_failures="$prev_entry"
            prev_last_restart="null"
        else
            prev_failures=$(echo "$prev_entry" | jq -r '.failures // 0')
            prev_last_restart=$(echo "$prev_entry" | jq -r '.last_restart // "null"')
        fi

        local status_desc
        if [[ "$http_code" == "000" ]]; then
            status_desc="connection refused"
        else
            status_desc="HTTP ${http_code}"
        fi

        if [[ "$http_code" =~ ^[23] ]]; then
            # Healthy — reset failures
            hc_data=$(echo "$hc_data" | jq --arg name "$name" --arg status "$status_desc" --arg ts "$now" \
                '.[$name] = {failures: 0, last_status: $status, last_check: $ts, last_restart: null}')
        else
            # Failed — increment counter
            local new_count=$((prev_failures + 1))

            log_event "warn" "healthcheck" "$name" "port ${port} ${status_desc} (${new_count} consecutive)"

            local should_restart=false
            if (( new_count >= 2 )); then
                # Backoff: skip restart if last restart was <5 minutes ago
                if [[ "$prev_last_restart" != "null" && -n "$prev_last_restart" ]]; then
                    local last_epoch now_epoch
                    last_epoch=$(date -d "$prev_last_restart" +%s 2>/dev/null || echo 0)
                    now_epoch=$(date -u +%s)
                    if (( now_epoch - last_epoch < 300 )); then
                        log_event "warn" "healthcheck" "$name" "skipping restart, last restart was <5m ago"
                    else
                        should_restart=true
                    fi
                else
                    should_restart=true
                fi
            fi

            if [[ "$should_restart" == true ]]; then
                log_event "warn" "healthcheck" "$name" "restarting after ${new_count} failures (${status_desc})"
                local svc="$(service_name "$name")"
                systemctl --user restart "$svc" 2>/dev/null || true

                # Check readiness after restart (10s timeout)
                if wait_for_ready "$name" "$port" 10; then
                    log_event "info" "healthcheck" "$name" "service restarted and ready"
                    status_desc="healthy after restart"
                    new_count=0
                else
                    log_event "warn" "healthcheck" "$name" "service restarted but not ready"
                fi

                hc_data=$(echo "$hc_data" | jq --arg name "$name" --argjson c "$new_count" \
                    --arg status "$status_desc" --arg ts "$now" \
                    '.[$name] = {failures: $c, last_status: $status, last_check: $ts, last_restart: $ts}')
            else
                hc_data=$(echo "$hc_data" | jq --arg name "$name" --argjson c "$new_count" \
                    --arg status "$status_desc" --arg ts "$now" --arg lr "$prev_last_restart" \
                    '.[$name] = {failures: $c, last_status: $status, last_check: $ts, last_restart: (if $lr == "null" then null else $lr end)}')
            fi
        fi
    done

    echo "$hc_data" > "$hc_state"
}

cmd_web() {
    local port="${1:-7000}"
    local script_dir
    for dir in "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/web" \
               "$HOME/.local/share/devtunnel/web"; do
        if [[ -f "$dir/app.py" ]]; then
            info "Starting web UI on http://127.0.0.1:${port}"
            export DEVTUNNEL_DOMAIN="$DOMAIN"
            export DEVTUNNEL_TUNNEL_ID="$TUNNEL_ID"
            exec python3 "$dir/app.py"
        fi
    done
    die "Web UI not found. Install it to ~/.local/share/devtunnel/web/"
}

# ---- Main ----

case "${1:-help}" in
    add)      shift; cmd_add "$@" ;;
    rm)       shift; cmd_rm "$@" ;;
    set)      shift; cmd_set "$@" ;;
    ls)       cmd_ls ;;
    restart)  shift; cmd_restart "$@" ;;
    stop)     shift; cmd_stop "$@" ;;
    logs)     shift; cmd_logs "$@" ;;
    log)      shift; cmd_log "$@" ;;
    status)   cmd_status ;;
    codes)    shift; cmd_codes "$@" ;;
    healthcheck) cmd_healthcheck ;;
    web)      shift; cmd_web "$@" ;;
    help|-h|--help) cmd_help ;;
    *) die "Unknown command: $1. Run 'devtunnel help' for usage." ;;
esac
